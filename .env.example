# ============================================================
# mailHunt — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ─── Database ────────────────────────────────────────────────────────────────
# SQLite — no change needed for local dev.
# For production (Vercel), use a hosted DB like Turso or PlanetScale.
DATABASE_URL="file:./dev.db"

# ─── Discovery Provider Chain ────────────────────────────────────────────────
# Providers are tried in priority order. Each falls through if rate-limited or empty.

# 1. Snov.io  — 150 credits/month — https://app.snov.io/account/api
#    Handles both people discovery AND email finding.
SNOV_CLIENT_ID=""
SNOV_CLIENT_SECRET=""

# 2. GitHub — FREE, no key required — 10 req/min unauth, 30 req/min with token
#    Finds real employees from public GitHub profiles (most reliable for tech cos)
#    Get token at: github.com/settings/tokens (no special scopes needed)
GITHUB_TOKEN=""

# 3. Hunter.io — 25 searches/month — https://hunter.io/api-documentation
#    Returns people AND their emails in a single call. Great fallback.
HUNTER_API_KEY=""

# 4. SerpAPI — 100 searches/month — https://serpapi.com
#    Google X-Ray: LinkedIn · company pages · engineering blogs · GitHub · press
SERPAPI_KEY=""

# 5. Google Custom Search Engine — 100 queries/day FREE (3,000/month)
#    Setup: https://programmablesearchengine.google.com → New search engine →
#      Sites to search: linkedin.com/in/* → Copy the "Search engine ID" (cx)
#    Then: https://console.cloud.google.com → Custom Search API → Enable → Create API key
GOOGLE_CSE_API_KEY=""
GOOGLE_CSE_CX=""

# 6. Bing Web Search API — 1,000 queries/month FREE via Azure
#    Setup: https://portal.azure.com → Create resource → Bing Search v7 →
#      Free tier F0 (1,000 req/month) → Keys and Endpoint → copy Key 1
BING_SEARCH_API_KEY=""

# ─── Email Resolution Providers ──────────────────────────────────────────────
# ZeroBounce — 100 validations/month — https://zerobounce.net
#    SMTP verifier: checks if a generated email format is deliverable.
#    Get key at: app.zerobounce.net > API
ZEROBOUNCE_API_KEY=""

# Abstract API — ~100 requests/month — https://www.abstractapi.com/api/email-verification-api
#    Email deliverability checker. Fallback after ZeroBounce.
#    Get key at: app.abstractapi.com > Email Verification API
ABSTRACTAPI_EMAIL_KEY=""

# ─── Employment Verification ─────────────────────────────────────────────────
# Apollo.io — People Match API — FREE 50 exports/month
#    Confirms current employer, surfaces LinkedIn URL, job title, seniority.
#    Get key at: https://app.apollo.io/settings/integrations/api_keys
APOLLO_API_KEY=""

# ─── Email Sending ───────────────────────────────────────────────────────────
# Gmail address you want to send from
EMAIL_USER=""
# Create an App Password at: myaccount.google.com/apppasswords
# (Requires 2FA enabled on your Google account — use the 16-char password, no spaces)
EMAIL_APP_PASSWORD=""

# ─── Admin ───────────────────────────────────────────────────────────────────
# Secret token for the DELETE /api/contacts admin endpoint
# Set to any random string, e.g.: openssl rand -hex 32
ADMIN_SECRET=""
